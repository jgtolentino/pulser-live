{
  "version": 2,
  "buildCommand": "pnpm install && pnpm build",
  "outputDirectory": "server/dist/public",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD",
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
} 